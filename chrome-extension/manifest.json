{
  "manifest_version": 3,
  "name": "GM War Room — ESPN",
  "version": "1.4.1",
  "description": "Connect ESPN Fantasy credentials to GM War Room using your logged-in session.",
  "permissions": ["cookies", "tabs", "scripting", "declarativeNetRequest", "declarativeNetRequestWithHostAccess"],
  "host_permissions": [
    "https://fantasy.espn.com/*",
    "https://lm-api-reads.fantasy.espn.com/*",
    "https://www.espn.com/*",
    "https://*.espn.com/*",
    "https://gmwarroom.online/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gmwarroom.online/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["gmwarroom-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "GM War Room",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
