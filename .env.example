# ============================================================
# ESPN Fantasy Football GM Tool — Environment Variables
# Copy this file to .env and fill in all required values.
# Required vars are marked [REQUIRED]. Optional are [OPTIONAL].
# ============================================================

# ── Database ─────────────────────────────────────────────────
# [REQUIRED] MySQL connection string
# Railway: copy from your MySQL plugin's DATABASE_URL variable
DATABASE_URL=mysql://user:password@host:3306/dbname

# ── App Identity ─────────────────────────────────────────────
# [REQUIRED] Random 32+ character secret for JWT session cookies
JWT_SECRET=replace_with_32_char_random_secret

# [OPTIONAL] Manus OAuth — only needed if using Manus login
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# ── Anthropic (AI Features) ───────────────────────────────────
# [REQUIRED] Anthropic API key for GM Advisor, Weekly Intel, DNA profiles
ANTHROPIC_API_KEY=sk-ant-api03-...
# [OPTIONAL] Override the default model (claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=

# ── ESPN Credentials ─────────────────────────────────────────
# [REQUIRED] Your ESPN fantasy league ID (number in the URL)
ESPN_LEAGUE_ID=123456
# [REQUIRED] ESPN auth cookie — get from browser DevTools > Application > Cookies > espn_s2
ESPN_S2=AE...
# [REQUIRED] ESPN auth cookie — get from browser DevTools > Application > Cookies > SWID
ESPN_SWID={XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}
# [REQUIRED] 32-character AES-256 key for encrypting stored league credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=replace_with_64_hex_chars

# ── Stripe (Payments) ─────────────────────────────────────────
# [OPTIONAL] Required only if enabling subscription payments
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...

# ── The Odds API (Vegas Lines) ────────────────────────────────
# [OPTIONAL] Required for Vegas odds features in Weekly Intel
THE_ODDS_API_KEY=

# ── Manus Built-in APIs ───────────────────────────────────────
# [OPTIONAL] Only needed when running inside Manus platform
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── Clerk Authentication ──────────────────────────────────────
# [REQUIRED] Get from Clerk Dashboard → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── Runtime ───────────────────────────────────────────────────
# [OPTIONAL] Railway sets this automatically
PORT=3000
NODE_ENV=production
