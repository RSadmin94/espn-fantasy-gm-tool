{
  "manifest_version": 3,
  "name": "ESPN GM Tool — League Connector & DNA Advisor",
  "short_name": "GM Connector",
  "version": "1.6.0",
  "description": "Connects your ESPN Fantasy league to the GM Tool and injects DNA Advisor badges on ESPN pages — click any badge to see a team's full DNA profile.",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://fantasy.espn.com/*",
    "https://www.espn.com/*",
    "https://espnfftool-d7edtbt5.manus.space/*",
    "https://*.manus.space/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Open DNA Advisor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://fantasy.espn.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://fantasy.espn.com/*"],
      "js": ["src/inject.js"],
      "css": ["src/inject.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://fantasy.espn.com/*"]
    }
  ]
}
